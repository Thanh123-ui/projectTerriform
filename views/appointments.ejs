<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Danh sách lịch hẹn | MediCare Clinic</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <%- include('partials/header') %>

  <main class="page">
    <div class="container">
      <div class="page-header page-header-row">
        <div>
          <span class="section-kicker">Quản lý lịch hẹn</span>
          <h1>Danh sách lịch hẹn</h1>
          <p>Theo dõi thông tin bệnh nhân và lịch khám một cách trực quan.</p>
        </div>

        <a href="/book" class="btn btn-primary">Tạo lịch mới</a>
      </div>

      <div class="table-card">
        <div class="table-wrap">
          <table class="appointment-table">
            <thead>
              <tr>
                <th>Họ tên</th>
                <th>SĐT</th>
                <th>Email</th>
                <th>Ngày</th>
                <th>Giờ</th>
                <th>Lý do khám</th>
              </tr>
            </thead>
            <tbody>
              <% if (appointments && appointments.length > 0) { %>
                <% appointments.forEach(item => { %>
                  <tr>
                    <td><strong><%= item.name %></strong></td>
                    <td><%= item.phone %></td>
                    <td><%= item.email || '-' %></td>
                    <td><%= item.date %></td>
                    <td><%= item.time %></td>
                    <td><%= item.reason || '-' %></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="6" class="empty">Chưa có lịch hẹn nào.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>